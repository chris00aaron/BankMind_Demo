# ============================================================
# BankMind Backend — Variables de Entorno
# ============================================================

# --- Database ---
DB_URL=jdbc:postgresql://bankmind_bd:5432/BankMindBetta
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}

# --- JWT ---
JWT_SECRET=BankMindSecretKeyForJWTTokensMinimum256BitsRequiredForHS256Algorithm2024

# --- Email (Gmail App Password) ---
MAIL_PASSWORD=${MAIL_PASSWORD}
MAIL_FROM=${MAIL_FROM}

# --- Encryption (AES-256, exactamente 32 caracteres) ---
ENCRYPTION_KEY=BankMindAES256SecretKey32ByteLen

# --- CORS ---
CORS_ORIGINS=*

# --- Self-Training API ---
SELF_TRAINING_API_URL=http://api-selftrain:8001/retiro-atm

# ---- Prediction API ----
PREDICTION_API_URL=http://api-prediction:8000/api/atm